# AetherGro: System Environment Configurations

# Port for the Node/Express backend to listen on
PORT=5000

# MongoDB connection string (leave blank to activate fallback local file-based database)
# Example: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/aethergro?retryWrites=true&w=majority
MONGODB_URI=

# Secret key used for signing JWT tokens (use a strong random string in production)
JWT_SECRET=aethergro_secret_key_ultra_secure_13579

# Mode (development or production)
NODE_ENV=development
